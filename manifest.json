{
  "manifest_version": 3,
  "name": "URL Inspector & Dev Tools",
  "version": "1.1",
  "description": "URL tracking inspector, encoding/decoding tools, and VLI dev tools",
  "permissions": ["sidePanel", "activeTab", "scripting", "webNavigation", "storage", "tabs"],
  "background": {
    "service_worker": "dist/background/service-worker.js"
  },
  "side_panel": {
    "default_path": "dist/sidepanel/panel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content/content.js"]
    },
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content/extract-datav3.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content/get-github-stars.js"]
    }
  ],
  "action": {
    "default_title": "Open URL Inspector"
  },
  "devtools_page": "dist/devtools/devtools.html",
  "web_accessible_resources": [
    {
      "resources": ["dist/content/extract-datav3.js"],
      "matches": ["<all_urls>"]
    }
  ]
}